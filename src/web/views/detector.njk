{#
  detector.njk — the per-detector findings list (golden-path steps 3–4,
  GET /detectors/{id}).

  One detector's findings as its OWN scored, triaged list (PRD §4/§5): ranked
  highest score first, each row showing the subject, a severity tag and the score,
  and linking into the finding detail page (the figures that tripped it). Severity
  is a coloured tag, not the sort order — `score` ranks the list (PRD §5.3).
#}
{% extends "layout.njk" %}
{% set navActive = "detectors" %}

{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block beforeContent %}
  {{ govukBackLink({ text: "Back to detectors", href: "/detectors" }) }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <span class="govuk-caption-xl">Detector</span>
      <h1 class="govuk-heading-xl">{{ detector.title }}</h1>
      <p class="govuk-body-l">
        Findings ranked by score, highest first. Showing
        {{ detector.surfacedCount }} of {{ detector.total }}
        {{ "finding" if detector.total == 1 else "findings" }}
        (subject: {{ detector.scope }}){% if detector.hiddenCount > 0 %}, {{ detector.hiddenCount }} below the current threshold{% endif %}.
      </p>

      {#
        Live-threshold control (golden-path step 6): a plain GET form whose fields
        are the triage thresholds. Submitting re-requests this same page with the
        thresholds as query params — the server re-runs triage and re-renders the
        re-ranked/filtered list. No client state, no code change (ADR-009).
      #}
      <form method="get" action="{{ detector.href }}" class="govuk-!-margin-bottom-6">
        <div class="govuk-grid-row">
          <div class="govuk-grid-column-one-third">
            {{ govukInput({
              label: { text: "Minimum score" },
              hint: { text: "0 to 100" },
              id: "minScore",
              name: "minScore",
              type: "number",
              classes: "govuk-input--width-5",
              attributes: { min: "0", max: "100" },
              value: detector.thresholds.minScore
            }) }}
          </div>
          <div class="govuk-grid-column-one-third">
            {{ govukSelect({
              label: { text: "Minimum severity" },
              hint: { text: "Any or higher" },
              id: "minSeverity",
              name: "minSeverity",
              items: detector.severityOptions
            }) }}
          </div>
          <div class="govuk-grid-column-one-third">
            {{ govukInput({
              label: { text: "Limit" },
              hint: { text: "Max findings to show" },
              id: "limit",
              name: "limit",
              type: "number",
              classes: "govuk-input--width-5",
              attributes: { min: "1" },
              value: detector.thresholds.limit
            }) }}
          </div>
        </div>
        {{ govukButton({ text: "Apply thresholds" }) }}
        <a class="govuk-link govuk-!-margin-left-3" href="{{ detector.href }}">Reset</a>
      </form>

      <p class="govuk-body">
        <a class="govuk-link" href="{{ detector.exportHref }}" download>Download these results (CSV)</a>
      </p>

      {% set rows = [] %}
      {% for r in detector.rows %}
        {% set rows = (rows.push([
          { html: '<a class="govuk-link" href="' + r.href + '">' + (r.label | escape) + '</a>' },
          { html: govukTag({ text: r.severity, classes: r.severityTag }) },
          { text: r.score, format: "numeric" }
        ]), rows) %}
      {% endfor %}

      {{ govukTable({
        caption: "Ranked findings",
        captionClasses: "govuk-table__caption--m",
        firstCellIsHeader: false,
        head: [
          { text: "Subject" },
          { text: "Severity" },
          { text: "Score", format: "numeric" }
        ],
        rows: rows
      }) }}
    </div>
  </div>
{% endblock %}
